from collections import defaultdict

# Initialize a dictionary to store confidence scores for each class
class_confidences = defaultdict(list)

# Iterate through each prediction
for i in range(len(y_pred)):
    predicted_class_index = y_pred_classes[i]
    # Get the confidence for the predicted class
    confidence = y_pred[i][predicted_class_index]
    class_confidences[predicted_class_index].append(confidence)

# Calculate the average confidence for each class
average_confidences = {}
for class_index, conf_list in class_confidences.items():
    average_confidences[class_index] = np.mean(conf_list)

# Map class indices back to song names and print results
print("\nAverage Confidence Scores Per Class:")
sorted_class_indices = sorted(average_confidences.keys())
for class_index in sorted_class_indices:
    song_name = encoder.inverse_transform([class_index])[0]
    avg_conf = average_confidences[class_index]
    print(f"- {song_name}: {avg_conf:.4f}")
