# 2. Load YOLOv8 Pose Model
# You can choose different sizes, e.g., 'yolov8s-pose.pt' for 'small' or 'yolov8l-pose.pt' for 'large'
model = YOLO('yolov8n-pose.pt') # 'n' for nano, a fast and lightweight model

# Custom styling for visualization (matching the 'Bora Purple' theme)
custom_kpt_color = (128, 0, 128) # Purple (BGR)
custom_line_color = (255, 255, 255) # White (BGR)

# COCO 17 keypoints (standard order for YOLOv8-pose)
# Nose, Left Eye, Right Eye, Left Ear, Right Ear,
# Left Shoulder, Right Shoulder, Left Elbow, Right Elbow, Left Wrist, Right Wrist,
# Left Hip, Right Hip, Left Knee, Right Knee, Left Ankle, Right Ankle

# Define skeleton connections for COCO 17 keypoints (tuples of keypoint indices)
POSE_PAIRS = [
    (0, 1), (0, 2), (1, 3), (2, 4), # Head/Face
    (5, 6), (5, 7), (6, 8), (7, 9), (8, 10), # Arms
    (11, 12), (5, 11), (6, 12), # Torso
    (11, 13), (12, 14), (13, 15), (14, 16) # Legs
]

# 3. Path Setup (Ensure these match your Drive exactly)
input_path = '/content/drive/MyDrive/Boraflow/BTS  FIRE  mirrored Dance Practice_1080p.mp4'
output_folder = '/content/drive/MyDrive/BoraFlow_YOLO_Skeletons/' # Changed output folder to Google Drive

if not os.path.exists(output_folder):
    os.makedirs(output_folder)

# This will be the temporary video file without audio
temp_output_filename = os.path.join(output_folder, 'temp_skele_YOLO_BTS_FIRE_mirrored_Dance_Practice_1080p.mp4')

cap = cv2.VideoCapture(input_path)
width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
fps    = cap.get(cv2.CAP_PROP_FPS)

# Setup the output video file (without audio initially)
fourcc = cv2.VideoWriter_fourcc(*'mp4v') # Codec for .mp4 output
out = cv2.VideoWriter(temp_output_filename, fourcc, fps, (width, height))

print(f"Processing video: {input_path}")

frame_count = 0
while cap.isOpened():
    ret, frame = cap.read()
    if not ret: # Process entire video, no frame limit
        break

    # Perform inference with YOLOv8-pose
    results = model(frame, verbose=False) # verbose=False to suppress extensive logging per frame

    # Process results and draw skeletons
    for r in results:
        if r.keypoints.data.shape[0] > 0: # Check if any keypoints are detected
            # Keypoints are typically in (num_people, num_keypoints, 3) format (x, y, confidence)
            for person_keypoints in r.keypoints.data:
                # Draw keypoints
                for kpt in person_keypoints:
                    x, y, conf = int(kpt[0]), int(kpt[1]), kpt[2]
                    if conf > 0.5: # Only draw keypoints with confidence > 0.5
                        cv2.circle(frame, (x, y), 5, custom_kpt_color, -1)

                # Draw connections (skeleton)
                for pair in POSE_PAIRS:
                    kpt1_idx, kpt2_idx = pair
                    kpt1 = person_keypoints[kpt1_idx]
                    kpt2 = person_keypoints[kpt2_idx]

                    x1, y1, conf1 = int(kpt1[0]), int(kpt1[1]), kpt1[2]
                    x2, y2, conf2 = int(kpt2[0]), int(kpt2[1]), kpt2[2]

                    if conf1 > 0.5 and conf2 > 0.5: # Only draw lines if both keypoints are confident
                        cv2.line(frame, (x1, y1), (x2, y2), custom_line_color, 2)

    out.write(frame)

    if frame_count % (int(fps) * 10) == 0: # Print progress every 10 seconds of video
        print(f"Processing Frame {frame_count}...")
        # cv2_imshow(cv2.resize(frame, (480, 270))) # Disabled for full video processing to save time

    frame_count += 1

cap.release()
out.release()
print(f"\nTemporary video (without audio) saved as {temp_output_filename}")
print("Next, we will add the audio and create the final video.")
